# Language-neutral exclusions

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Build / dist
build/
dist/
out/
target/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency caches
.cache/
.parcel-cache/

# Environment files
.env
.env.local
.env.*.local

# Test coverage
coverage/
.coverage
htmlcov/
.nyc_output/

# Python (uncomment if using Python)
# __pycache__/
# *.py[cod]
# *.egg-info/
# .venv/
# venv/
# .pytest_cache/
# .ruff_cache/
# .mypy_cache/

# Node.js (uncomment if using Node)
# node_modules/
# .pnpm-store/

# Rust (uncomment if using Rust)
# target/
# Cargo.lock

# Go (uncomment if using Go)
# vendor/

# Java (uncomment if using Java)
# *.class

# Data (customize per project - often excluded from git)
# data/
